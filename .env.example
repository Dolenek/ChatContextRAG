# Copy this file to .env and add local secrets there.
# Leave unused integrations blank. Never commit the populated .env file.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_BATCH_SIZE=64
OPENAI_CHAT_MODEL=gpt-5.6-luna

# Local PostgreSQL + pgvector configuration.
POSTGRES_USER=chat_context
POSTGRES_PASSWORD=
POSTGRES_DB=chat_context
POSTGRES_PORT=5433
POSTGRES_DSN=

# Linux web profile. Generate secure values with: npm run web:secrets
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=8080
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD_HASH=
WEB_SESSION_HOURS=12
WEB_TRUST_PROXY=0
CHAT_CONTEXT_SERVER_KEY=
CHAT_CONTEXT_DESKTOP_TOKEN=
CHAT_CONTEXT_INTERNAL_TOKEN=
