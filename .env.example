# Copy this file to .env and add local secrets there.
# Leave unused integrations blank. Never commit the populated .env file.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_EMBEDDING_BATCH_SIZE=64
OPENAI_CHAT_MODEL=gpt-5.6-luna

# Local PostgreSQL + pgvector configuration.
POSTGRES_USER=chat_context
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chat_context
POSTGRES_PORT=5433
POSTGRES_DSN=postgresql://chat_context:change-me@127.0.0.1:5433/chat_context
